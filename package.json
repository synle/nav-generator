{
  "name": "synle-nav-generator",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Application to organize and generate bookmarks",
  "main": "index.html",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.55.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "scripts": {
    "clean": "rm -rf import-map.json .prettier-cache",
    "prebuild": "curl -sfL -H 'Accept: application/vnd.github.raw' https://api.github.com/repos/synle/bashrc/contents/webapp/common.scss -o common.scss",
    "build": "NODE_ENV=production vite build",
    "format": "npx --yes prettier --write --cache --ignore-unknown --no-error-on-unmatched-pattern --print-width 140 .",
    "start": "npx http-server --cors -a 127.0.0.1 .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "Sy",
    "Le"
  ],
  "author": "Sy Le",
  "license": "ISC",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "c8": "^11.0.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "sass": "^1.99.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
